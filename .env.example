DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database — leave unset to use SQLite in the project directory
# For Cloud Run / Postgres: DATABASE_URL=postgres://user:pass@host/dbname
# DATABASE_URL=

STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx

BOOKING_HOLD_MINUTES=10

# Stripe webhook signing secret — set this when you configure the webhook endpoint in Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# Email (for password reset) – leave commented to use console backend in dev
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@silvacare.org.uk
